    <div class="alert alert-warning shadow-sm p-4">
        <h4 class="mb-3">⚠️ Oficio bloqueado</h4>

        <p class="mb-2">
            El oficio <strong>{{ oficio.numero }}</strong> ya se encuentra 
            <span class="badge bg-success">Solucionado</span>.
